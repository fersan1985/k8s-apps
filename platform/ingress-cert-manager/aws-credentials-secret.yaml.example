---
# AWS Credentials for cert-manager (Let's Encrypt DNS-01 challenge)
# IMPORTANTE: Copia este archivo como aws-credentials-secret.yaml y completa con tus credenciales
# NO commitees el archivo real con credenciales a Git
apiVersion: v1
kind: Secret
metadata:
  name: cert-manager-route53
  namespace: cert-manager
type: Opaque
stringData:
  # Completa con tu AWS Secret Access Key
  # El Access Key ID se especifica en el ClusterIssuer
  secret-access-key: "YOUR_AWS_SECRET_ACCESS_KEY"
