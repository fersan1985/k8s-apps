---
# AWS Credentials for ExternalDNS
# IMPORTANTE: Copia este archivo como aws-credentials-secret.yaml y completa con tus credenciales
# NO commitees el archivo real con credenciales a Git
apiVersion: v1
kind: Secret
metadata:
  name: external-dns-aws
  namespace: external-dns
type: Opaque
stringData:
  # Completa con tu AWS Access Key ID
  aws_access_key_id: "YOUR_AWS_ACCESS_KEY_ID"
  # Completa con tu AWS Secret Access Key
  aws_secret_access_key: "YOUR_AWS_SECRET_ACCESS_KEY"
